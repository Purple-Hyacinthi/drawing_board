# Drawing Board Pro 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ============ 应用配置 ============
APP_NAME="Drawing Board Pro"
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_URL=http://localhost:8080

# ============ 数据库配置 ============
# PostgreSQL 配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=drawing_board
DB_USER=postgres
DB_PASSWORD=password

# 连接池配置
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000

# ============ JWT 认证配置 ============
JWT_SECRET=your-jwt-secret-key-change-in-production-32-characters-min
JWT_EXPIRATION=86400  # 24小时
JWT_REFRESH_EXPIRATION=604800  # 7天

# ============ 文件存储配置 ============
# 存储类型: local, s3, azure
STORAGE_TYPE=local
STORAGE_PATH=./uploads
STORAGE_MAX_SIZE=104857600  # 100MB

# AWS S3 配置 (如果使用S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ============ 邮件配置 ============
# SMTP 服务器配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@drawingboard.com
SMTP_ENCRYPTION=tls

# ============ 前端配置 ============
VITE_API_BASE_URL=http://localhost:8080/api
VITE_APP_NAME=Drawing Board Pro
VITE_APP_VERSION=1.0.0

# ============ 缓存配置 ============
# Redis 配置 (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============ 安全配置 ============
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000  # 1分钟

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10485760  # 10MB
LOG_MAX_FILES=10

# ============ 监控配置 ============
METRICS_ENABLED=true
TRACING_ENABLED=false
PROFILING_ENABLED=false

# ============ 功能开关 ============
FEATURE_USER_REGISTRATION=true
FEATURE_EMAIL_VERIFICATION=false
FEATURE_SOCIAL_LOGIN=false
FEATURE_REALTIME_COLLABORATION=false
FEATURE_CLOUD_SYNC=false

# ============ 第三方服务 ============
# Google OAuth (如果启用社交登录)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (如果启用社交登录)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe 支付 (如果启用付费功能)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============ 开发工具配置 ============
# 仅开发环境使用
DEVELOPMENT_MODE=true
HOT_RELOAD=true
DEBUG_PORT=5005

# ============ 测试配置 ============
# 测试环境专用
TEST_DB_NAME=drawing_board_test
TEST_DB_RESET=true